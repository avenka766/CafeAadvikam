# .env.example
# Copy this file to .env.local and fill in your own Supabase project values.
# NEVER commit .env.local — it is git-ignored.
# These VITE_ variables are bundled into client-side JS — keep them to anon/public keys only.
# Service-role keys must NEVER appear here; use Supabase Edge Functions instead.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
